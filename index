      setupDropZone('#comparisonDrop', 'comparison');
      $('#usePoint').addEventListener('change', updateUsePoint);
      $$('input[name="analysisMode"]').forEach(control => control.addEventListener('change', updateAnalysisModeUI));
      $('#analysisStrategy').addEventListener('change', renderPreflight);
      $('[data-pick="plan"]').addEventListener('click', () => $('#planFile').click());
      $('[data-pick="comparison"]').addEventListener('click', () => $('#comparisonFiles').click());
      $('#planFile').addEventListener('change', event => { setFiles('plan', event.target.files); event.target.value = ''; });
      $('#comparisonFiles').addEventListener('change', event => { setFiles('comparison', event.target.files); event.target.value = ''; });
      document.addEventListener('click', event => {
        const remove = event.target.closest('[data-remove-role]');
        if (!remove) return;
        if (remove.dataset.removeRole === 'plan') state.planFile = null;
        else state.comparisonFiles.splice(Number(remove.dataset.removeIndex), 1);
        renderFileLists();
      });
      document.addEventListener('input', event => {
        const control = event.target.closest('[data-profile-key][data-profile-field]');
        if (!control) return;
        const profile = state.documentProfiles[control.dataset.profileKey];
        if (profile) profile[control.dataset.profileField] = control.value;
        state.checkpoints = [];
        state.checkpointSignature = '';
        renderPreflight();
      });
      $('#toggleKey').addEventListener('click', () => {
        const input = $('#apiKey');
        const show = input.type === 'password';
        input.type = show ? 'text' : 'password';
        $('#toggleKey').textContent = show ? '숨김' : '표시';
      });
      $('#apiKey').addEventListener('input', () => { if (state.apiConnected) setApiState('', '키 변경됨'); });
      $('#clearKey').addEventListener('click', () => { $('#apiKey').value = ''; setApiState('', 'API 연결 전'); $('#apiKey').focus(); });
      $('#checkConnection').addEventListener('click', checkConnection);
      $('#testModel').addEventListener('click', testModelAccess);
      $('#continueIntegration').addEventListener('click', () => {
        if (!$('#baselineConfirmed').checked) { $('#baselineConfirmed').focus(); return; }
        const index = Number($('#baselineDocument').value || 0);
        const files = [state.planFile,...state.comparisonFiles];
        const profile = documentProfile(files[index], index === 0 ? 'plan' : 'comparison', index);
        const approvalVerified = $('#baselineApprovalVerified').checked;
        const approvalEvidence = $('#baselineApprovalEvidence').value.trim();
        if (approvalVerified && !approvalEvidence) { $('#baselineApprovalEvidence').focus(); return; }
        state.baselineDecision = {document_id:profile.document_id,role:profile.role,status:approvalVerified ? '사용자 선택 · 원문 근거 확인' : '사용자 선택 · 원문 확인 전',approval_verified:approvalVerified,approval_evidence:approvalEvidence};
        const resolve = state.baselineResolver;
        state.baselineResolver = null;
        if (resolve) resolve(state.baselineDecision);
      });
      $('#resetAll').addEventListener('click', resetAll);
      $('#analysisForm').addEventListener('submit', event => { event.preventDefault(); if (state.actionsDirty && !window.confirm('후속조치 편집내용이 새 분석으로 대체됩니다. 계속할까요?')) return; state.actionsDirty = false; runAnalysis(); });
      $('#cancelAnalysis').addEventListener('click', () => { if (state.controller) state.controller.abort(); if (state.baselineResolver) { state.baselineResolver({cancelled:true}); state.baselineResolver = null; } $('#processDescription').textContent = '브라우저 요청을 중단했습니다. 이미 서버에서 처리 중인 요청은 과금될 수 있습니다.'; });
      $('#backToInput').addEventListener('click', () => setView('input'));
      $('#retryAnalysis').addEventListener('click', runAnalysis);
      $('#editInput').addEventListener('click', () => setView('input'));
      $('#newAnalysis').addEventListener('click', resetAll);
      $('#downloadJson').addEventListener('click', downloadResult);
      $('#printOutput').addEventListener('click', () => window.print());
      $('.tabs').addEventListener('click', event => { const button = event.target.closest('[data-tab]'); if (button) activateTab(button.dataset.tab); });
      $('.tabs').addEventListener('keydown', event => {
        const tabs = $$('.tab-button');
        const index = tabs.indexOf(document.activeElement);
        if (index < 0) return;
        let next = index;
        if (event.key === 'ArrowRight') next = (index + 1) % tabs.length;
        else if (event.key === 'ArrowLeft') next = (index - 1 + tabs.length) % tabs.length;
        else if (event.key === 'Home') next = 0;
        else if (event.key === 'End') next = tabs.length - 1;
        else return;
        event.preventDefault(); tabs[next].focus(); activateTab(tabs[next].dataset.tab);
      });
      window.addEventListener('beforeprint', () => {
        $$('[data-action-field="memo"]').forEach(area => { area.dataset.printHeight = area.style.height || ''; area.style.height = `${area.scrollHeight}px`; });
      });
      window.addEventListener('afterprint', () => {
        $$('[data-action-field="memo"]').forEach(area => { area.style.height = area.dataset.printHeight || ''; delete area.dataset.printHeight; });
      });
      window.addEventListener('beforeunload', event => { if (state.actionsDirty) { event.preventDefault(); event.returnValue = ''; } });
    });
  </script>
</body>
</html>
