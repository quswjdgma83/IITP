    function clearFormError() { $('#formError').classList.add('hidden'); $('#formError').textContent = ''; }

    function setFiles(role, files) {
      clearFormError();
      const chosen = Array.from(files || []);
      if (!chosen.length) return;
      const unsupported = chosen.find(file => !SUPPORTED_EXTENSIONS.has(fileExtension(file.name)));
      if (unsupported) {
        const ext = fileExtension(unsupported.name).toUpperCase();
        const message = ['HWP','HWPX'].includes(ext)
          ? `${unsupported.name}: HWP/HWPX는 브라우저 직접 API 방식에서 지원되지 않습니다. PDF 또는 DOCX로 변환해 주세요.`
          : `${unsupported.name}: 지원하지 않는 파일 형식입니다.`;
        showFormError(message);
        return;
      }
      if (role === 'plan') {
        state.planFile = chosen[0];
        documentProfile(state.planFile, 'plan', 0);
      }
      else {
        const known = new Set(state.comparisonFiles.map(file => `${file.name}:${file.size}:${file.lastModified}`));
        chosen.forEach(file => {
          const key = `${file.name}:${file.size}:${file.lastModified}`;
          if (!known.has(key)) { state.comparisonFiles.push(file); documentProfile(file, 'comparison', state.comparisonFiles.length); known.add(key); }
        });
      }
      state.checkpoints = [];
      state.checkpointSignature = '';
      renderFileLists();
    }

    function renderFileLists() {
      const render = (file, role, index = 0) => {
        const ext = fileExtension(file.name).toUpperCase();
        const profile = documentProfile(file, role, role === 'plan' ? 0 : index + 1);
        const roleOptions = role === 'plan'
          ? ['원계획','승인 변경계획']
          : ['원계획','승인 변경계획','협약변경 증빙','연차보고서','단계보고서','최종보고서','성과증빙','기타 비교자료'];
        return `<div class="file-item"><span class="file-type">${e(ext)}</span><div><div class="file-name">${e(file.name)}</div><div class="file-meta">${e(profile.document_id)} · ${bytes(file.size)}</div><div class="file-profile"><label><span class="metric-sub">문서 역할</span><select data-profile-key="${e(fileKey(file))}" data-profile-field="role">${roleOptions.map(value => `<option value="${e(value)}"${profile.role === value ? ' selected' : ''}>${e(value)}</option>`).join('')}</select></label><label><span class="metric-sub">대상 단계·기간</span><input data-profile-key="${e(fileKey(file))}" data-profile-field="stage" value="${e(profile.stage)}" placeholder="예: 1단계 3차년도"></label><label><span class="metric-sub">논리 문서 그룹</span><input data-profile-key="${e(fileKey(file))}" data-profile-field="logical_group" value="${e(profile.logical_group)}" placeholder="분할 조각은 같은 그룹명"></label></div></div><button class="file-remove" type="button" data-remove-role="${role}" data-remove-index="${index}" aria-label="${e(file.name)} 삭제">×</button></div>`;
      };
      $('#planFileList').innerHTML = state.planFile ? render(state.planFile, 'plan') : '';
      $('#comparisonFileList').innerHTML = state.comparisonFiles.map((file, index) => render(file, 'comparison', index)).join('');
      renderPreflight();
