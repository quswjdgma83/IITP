    function setProcessStep(index, status, note) {
      $$('.process-item').forEach((item, itemIndex) => {
        item.classList.toggle('active', itemIndex === index && status === 'active');
        if (itemIndex < index || (itemIndex === index && status === 'done')) item.classList.add('done');
        if (itemIndex > index) item.classList.remove('done');
        const stateLabel = $('.step-state', item);
        if (itemIndex < index || (itemIndex === index && status === 'done')) stateLabel.textContent = '완료';
        else if (itemIndex === index && status === 'active') stateLabel.textContent = note || '진행 중';
        else stateLabel.textContent = '대기';
      });
      const progress = status === 'done' ? (index + 1) * 20 : index * 20 + 8;
      $('#progressBar').style.width = `${progress}%`;
      $('#progressTrack').setAttribute('aria-valuenow', String(progress));
      $('#progressText').textContent = `${progress}%`;
    }

    function resetProcess() {
      state.diagnostic = null;
      $$('.process-item').forEach(item => { item.classList.remove('active','done'); $('.step-state', item).textContent = '대기'; });
      $('#progressBar').style.width = '0%';
      $('#progressTrack').setAttribute('aria-valuenow', '0');
      $('#progressText').textContent = '0%';
      $('#processError').classList.add('hidden');
      $('#processError').innerHTML = '';
      $('#retryAnalysis').classList.add('hidden');
      $('#cancelAnalysis').classList.remove('hidden');
      $('#backToInput').disabled = true;
      $('#baselineReview').classList.add('hidden');
      $('#baselineConfirmed').checked = false;
      $('#baselineApprovalVerified').checked = false;
      $('#baselineApprovalEvidence').value = '';
    }

