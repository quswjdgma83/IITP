    const fileKey = file => file ? `${file.name}:${file.size}:${file.lastModified}` : '';

    function defaultDocumentProfile(file, role, index = 0) {
      const documentId = `DOC-${String(state.nextDocumentNumber++).padStart(3,'0')}`;
