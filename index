    function buildDiagnostic(error) {
      const classification = classifyApiError(error);
      const context = error?.context || state.lastRequestMeta || {};
      return {
        captured_at: new Date().toISOString(),
        classification,
        http_status: Number(error?.status || 0) || null,
        error_type: sanitizeDiagnosticValue(error?.type || ''),
        error_code: sanitizeDiagnosticValue(error?.code || ''),
        error_param: sanitizeDiagnosticValue(error?.param || ''),
        error_message: sanitizeDiagnosticValue(error?.message || '알 수 없는 오류'),
        request_id: sanitizeDiagnosticValue(error?.requestId || error?.headers?.['x-request-id'] || ''),
        client_request_id: sanitizeDiagnosticValue(error?.clientRequestId || context.client_request_id || ''),
        response_headers: Object.fromEntries(Object.entries(error?.headers || {}).map(([key,value]) => [key, sanitizeDiagnosticValue(value)])),
        request_summary: context,
        response_summary: error?.responseMeta || {},
        recommended_action: diagnosticAdvice(classification),
        privacy_note: 'API Key, Authorization 헤더, 문서 내용과 파일명은 포함하지 않음'
      };
    }

    function setView(view) {
      ['input','process','output'].forEach(name => {
        $(`#view-${name}`).classList.toggle('hidden', name !== view);
        const step = $(`[data-workflow="${name}"]`);
        step.classList.toggle('active', name === view);
        const order = {input:0, process:1, output:2};
        step.classList.toggle('done', order[name] < order[view]);
      });
      window.scrollTo({top: 0, behavior: 'smooth'});
    }

    function setApiState(kind, label) {
      const apiState = $('#apiState');
      apiState.className = `api-state ${kind || ''}`;
      apiState.textContent = label;
      const badge = $('#sessionBadge');
      badge.classList.toggle('connected', kind === 'ok');
      $('#sessionLabel').textContent = kind === 'ok' ? 'API 연결됨' : label;
      state.apiConnected = kind === 'ok';
    }

    function populateModels(models, selected) {
      const liveModels = [...new Set(models)].filter(id => /^gpt-5(?:$|[.\-])/i.test(id));
      const unique = (liveModels.length ? liveModels : FALLBACK_MODELS).slice();
      state.verifiedModels = liveModels;
      unique.sort((a, b) => {
        const preferred = model => FALLBACK_MODELS.indexOf(model);
        const ai = preferred(a), bi = preferred(b);
        if (ai >= 0 && bi >= 0) return ai - bi;
        if (ai >= 0) return -1;
        if (bi >= 0) return 1;
        return b.localeCompare(a, undefined, {numeric:true});
      });
      $('#modelSelect').innerHTML = unique.map(id => `<option value="${e(id)}">${e(id)}${id === 'gpt-5.6' ? ' · 권장' : ''}${liveModels.length ? ' · 접근 확인' : ' · 확인 필요'}</option>`).join('');
      $('#modelSelect').value = unique.includes(selected) ? selected : (unique.includes('gpt-5.6') ? 'gpt-5.6' : unique[0] || '');
    }

    async function checkConnection() {
      const key = $('#apiKey').value.trim();
      if (!key) {
        setApiState('bad', 'API Key 필요');
        $('#apiKey').focus();
        return;
      }
      const button = $('#checkConnection');
      button.disabled = true;
      button.textContent = '확인 중…';
      setApiState('', '연결 확인 중');
      try {
        const clientRequestId = createClientRequestId('rnd-model-list');
        const response = await fetch('https://api.openai.com/v1/models', {
          headers: {Authorization: `Bearer ${key}`, 'X-Client-Request-Id': clientRequestId},
          cache: 'no-store'
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok) throw apiError(response, data, {endpoint:'GET /v1/models', client_request_id:clientRequestId});
        const selected = $('#modelSelect').value;
        const models = array(data.data).map(item => item.id).filter(id => /^gpt-5(?:$|[.\-])/i.test(id));
        populateModels(models, selected);
        setApiState('ok', models.length ? `${models.length}개 GPT-5 모델 확인` : '연결됨 · 기본 모델 목록 유지');
      } catch (error) {
        setApiState('bad', '연결 실패');
        showFormError(describeError(error));
      } finally {
        button.disabled = false;
        button.textContent = 'API 연결 확인';
      }
    }

    async function testModelAccess() {
      const key = $('#apiKey').value.trim();
      const model = $('#modelSelect').value;
      const box = $('#probeResult');
      const button = $('#testModel');
      if (!key) { setApiState('bad', 'API Key 필요'); $('#apiKey').focus(); return; }
      button.disabled = true;
      button.textContent = '진단 중…';
      box.className = 'probe-result';
      box.textContent = '문서 없이 최소 Responses API 호출을 실행하고 있습니다.';
      const clientRequestId = createClientRequestId('rnd-probe');
      const context = {endpoint:'POST /v1/responses · structured-output probe', model, document_count:0, max_output_tokens:256, client_request_id:clientRequestId};
      try {
        const response = await fetch('https://api.openai.com/v1/responses', {
          method:'POST',
          headers:{'Content-Type':'application/json', Authorization:`Bearer ${key}`, 'X-Client-Request-Id':clientRequestId},
          body:JSON.stringify({model, store:false, reasoning:{effort:'low'}, max_output_tokens:256, text:{verbosity:'low',format:{type:'json_schema',name:'rnd_probe',strict:true,schema:{type:'object',additionalProperties:false,properties:{status:{type:'string',enum:['ok']}},required:['status']}}}, input:'Return a JSON object whose status is ok.'}),
          cache:'no-store'
        });
        const data = await response.json().catch(() => ({}));
        if (!response.ok) throw apiError(response, data, context);
        const probeText = extractOutputText(data);
        const probe = JSON.parse(normalizeStructuredOutput(probeText));
        if (data.status !== 'completed' || probe.status !== 'ok') throw responseProcessingError('structured_output_missing','Structured Output 진단이 완료되지 않았습니다.',response,data,context,probeText);
        const headers = collectResponseHeaders(response);
        const requestId = headers['x-request-id'] || data?._request_id || '';
        box.className = 'probe-result ok';
        box.textContent = `Structured Output 호출 성공 · ${model}${requestId ? ` · request ${requestId}` : ''}. 인증·모델 접근·JSON Schema 응답이 정상입니다.`;
        setApiState('ok', '모델 호출 성공');
      } catch (error) {
        state.diagnostic = buildDiagnostic(error);
        box.className = 'probe-result bad';
        box.innerHTML = `<strong>모델 호출 실패 · ${e(state.diagnostic.classification)}</strong><br>${e(state.diagnostic.error_message)}<br><small>${e(state.diagnostic.recommended_action)}</small><div style="margin-top:8px"><button class="btn btn-small" type="button" id="copyProbeDiagnostic">진단정보 복사</button></div>`;
        $('#copyProbeDiagnostic').addEventListener('click', () => copyDiagnosticPayload($('#copyProbeDiagnostic')));
        setApiState('bad', '모델 호출 실패');
      } finally {
        button.disabled = false;
        button.textContent = '모델 호출 진단';
      }
    }

    function apiError(response, data, context = {}) {
      const message = data?.error?.message || `API 요청 실패 (${response.status})`;
      const error = new Error(message);
      error.status = response.status;
      error.type = data?.error?.type || '';
      error.code = data?.error?.code || '';
      error.param = data?.error?.param || '';
      error.headers = collectResponseHeaders(response);
      error.requestId = error.headers['x-request-id'] || data?._request_id || '';
      error.clientRequestId = context.client_request_id || '';
      error.context = context;
      return error;
    }

    function describeError(error) {
      if (error?.name === 'AbortError') return '사용자가 분석을 중단했습니다.';
      if (error?.code === 'max_output_tokens') return '추론과 JSON 출력이 최대 출력 토큰 안에 끝나지 않았습니다.';
      if (error?.code === 'model_refusal') return '모델이 분석 요청을 거절했습니다.';
      if (['structured_output_parse','structured_output_missing'].includes(error?.code)) return 'API 호출은 성공했지만 Structured Output을 사용할 수 없습니다.';
      if (error?.status === 401) return 'API Key가 유효하지 않거나 사용할 권한이 없습니다.';
      if (error?.status === 403) return '선택한 모델 또는 API에 접근할 권한이 없습니다.';
      if (error?.status === 429) {
        const classification = classifyApiError(error);
        if (classification === 'billing_or_quota') return '결제 크레딧 또는 조직·프로젝트 사용한도를 확인하세요.';
        if (classification === 'token_rate_limit') return '모델의 분당 토큰(TPM) 한도를 초과했습니다.';
        if (classification === 'image_rate_limit') return 'PDF 페이지 이미지 처리(IPM) 한도를 초과했을 가능성이 큽니다.';
        if (classification === 'request_rate_limit') return '분당 요청 횟수(RPM) 한도를 초과했습니다.';
        return `API 처리량 한도에 도달했습니다: ${error.message}`;
      }
      if (error?.status === 400) return `요청 형식을 처리하지 못했습니다: ${error.message}`;
      if (error instanceof TypeError && /fetch/i.test(error.message)) return '브라우저가 API 연결을 차단했거나 네트워크 연결에 실패했습니다. file:// 환경의 CORS 정책과 네트워크 상태를 확인하세요.';
      return error?.message || '알 수 없는 오류가 발생했습니다.';
    }

    function showFormError(message) {
