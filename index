    function validateResultShape(result) {
      const required = ['metadata','summary','technology_flow','performance_metrics','risks','comparisons','timeline','institutions','budget','questions','required_documents','limitations','evidence_index'];
      const missing = required.filter(key => !(key in result));
      if (missing.length) throw new Error(`분석 결과에 필수 영역이 없습니다: ${missing.join(', ')}`);
      const warnings = [...array(state.agentReferenceWarnings)];
      const evidenceList = array(result.evidence_index);
      const rawEvidenceIds = evidenceList.map(item => item.evidence_id).filter(Boolean);
      const evidenceIds = new Set(rawEvidenceIds);
      if (evidenceIds.size !== rawEvidenceIds.length) throw new Error('원문 근거 ID가 중복되어 결과를 안전하게 연결할 수 없습니다. 해당 통합 단계만 다시 실행하세요.');
      const documentIds = new Set([state.planFile,...state.comparisonFiles].filter(Boolean).map((file,index) => documentProfile(file,index===0?'plan':'comparison',index).document_id));
      const invalidEvidenceDocuments = evidenceList.filter(item => item.document_id && !documentIds.has(item.document_id));
      if (invalidEvidenceDocuments.length) throw new Error(`원문 근거의 document_id가 입력 문서와 일치하지 않습니다: ${invalidEvidenceDocuments.map(item=>item.document_id).join(', ')}`);
      const allowedStatuses = new Set(['초과 달성','달성','부분 달성','미달','미도래','판단 곤란','정보 불일치','비교 대상 없음']);
      const risks = array(result.risks);
      risks.forEach((risk,index) => { risk.risk_id = String(risk.risk_id || `R-${String(index + 1).padStart(3,'0')}`).trim(); });
      const riskIds = risks.map(risk => risk.risk_id);
      if (new Set(riskIds).size !== riskIds.length) throw new Error('위험 ID가 중복되어 결과를 안전하게 연결할 수 없습니다. 해당 통합 단계만 다시 실행하세요.');
      const invalidRiskIds = riskIds.filter(id => !/^R-[A-Za-z0-9_-]+$/i.test(id));
      if (invalidRiskIds.length) throw new Error(`위험 ID 형식이 올바르지 않습니다: ${invalidRiskIds.join(', ')}`);
      const riskById = new Map(risks.map(risk => [risk.risk_id,risk]));
      array(result.performance_metrics).forEach((metric, index) => {
        if (!allowedStatuses.has(metric.achievement_status)) {
          warnings.push(`성과지표 ${index + 1}: 알 수 없는 달성상태를 판단 곤란으로 정규화했습니다.`);
          metric.achievement_status = '판단 곤란';
        }
        const refs = array(metric.evidence_ids);
        const invalidRefs = refs.filter(id => !evidenceIds.has(id));
        if (invalidRefs.length) {
          warnings.push(`성과지표 ${index + 1}: 존재하지 않는 근거 ID ${invalidRefs.join(', ')}`);
          metric.evidence_ids = refs.filter(id => evidenceIds.has(id));
        }
        const actual = Number(metric.actual_value), target = Number(metric.target_value), min = Number(metric.target_min), max = Number(metric.target_max), tolerance = Math.max(0,Number(metric.tolerance || 0));
        let deterministic = '';
        const operatorMatches = {higher_better:'>=',lower_better:'<=',range:'range',exact:'=='}[metric.direction] === metric.operator;
        const numericReady = metric.type === '정량' && metric.calculation_applicable === true && metric.target_parsed === true && metric.actual_parsed === true && metric.unit_match === true && metric.condition_match === true && operatorMatches && Number.isFinite(actual);
        if (numericReady) {
          if (metric.direction === 'higher_better' && Number.isFinite(target)) deterministic = actual >= target ? (actual > target ? '초과 달성' : '달성') : '미달';
          else if (metric.direction === 'lower_better' && Number.isFinite(target)) deterministic = actual <= target ? '달성' : '미달';
          else if (metric.direction === 'exact' && Number.isFinite(target)) deterministic = Math.abs(actual - target) <= tolerance ? '달성' : '미달';
          else if (metric.direction === 'range' && Number.isFinite(min) && Number.isFinite(max) && max >= min) deterministic = actual >= min && actual <= max ? '달성' : '미달';
        } else if (metric.calculation_applicable === true) {
          warnings.push(`성과지표 ${index + 1}: 지표유형·방향·연산자·단위·측정조건 중 하나가 불일치하여 자동 계산을 중단했습니다.`);
          metric.achievement_status = '판단 곤란';
          metric.calculation_applicable = false;
          metric.achievement_rate_value = -1;
        }
        if (deterministic && !['미도래','정보 불일치','비교 대상 없음'].includes(metric.achievement_status) && deterministic !== metric.achievement_status) {
          warnings.push(`성과지표 ${index + 1} (${metric.name || '이름 없음'}): AI 판정 ${metric.achievement_status}을 구조화 수치 검증 결과 ${deterministic}으로 정정했습니다.`);
          metric.achievement_status = deterministic;
          metric.calculation_note = `클라이언트 교차검증: ${metric.direction} · ${metric.calculation_note || ''}`;
        }
        if ((!metric.direction || metric.direction === 'unknown') && /달성/.test(metric.achievement_status)) {
          warnings.push(`성과지표 ${index + 1}: 방향성 미확인으로 달성판정을 판단 곤란으로 격리했습니다.`);
          metric.achievement_status = '판단 곤란';
        }
        const linkedRisk = riskById.get(metric.risk_id);
        if (linkedRisk) metric.risk = normalizeRiskGrade(linkedRisk.grade);
        else {
          warnings.push(`성과지표 ${index + 1}: 연결된 risk_id ${metric.risk_id || '없음'}를 위험 원장에서 찾지 못해 보완권고로 격리했습니다.`);
          metric.risk = '보완권고';
        }
        if (!array(metric.evidence_ids).length && metric.risk === '정상') {
          warnings.push(`성과지표 ${index + 1}: 근거 ID가 없어 정상 등급을 보완권고로 조정했습니다.`);
          if (linkedRisk) linkedRisk.grade = '보완권고';
          metric.risk = '보완권고';
        }
      });
      risks.forEach((risk,index) => {
        const refs = array(risk.evidence_ids).filter(id => evidenceIds.has(id));
        if (refs.length !== array(risk.evidence_ids).length) warnings.push(`${risk.risk_id}: 유효하지 않은 근거 ID를 제외했습니다.`);
        risk.evidence_ids = refs;
        if (risk.grade === '정상' && !refs.length) {
          risk.grade = '보완권고';
          warnings.push(`${risk.risk_id}: 근거 없는 정상 판정을 보완권고로 조정했습니다.`);
        } else if (risk.grade !== '정상' && !refs.length) {
          risk.title = `근거 확인 필요 · ${risk.title || '검토항목'}`;
          risk.confidence = `낮음 · 원문 근거 ID 없음${risk.confidence ? ` · ${risk.confidence}` : ''}`;
          warnings.push(`${risk.risk_id}: 비정상 등급에 원문 근거가 없어 AI 분석의견으로 격리했습니다.`);
        }
      });
      array(result.comparisons).forEach((item,index) => {
        const refs = array(item.evidence_ids);
        const invalidRefs = refs.filter(id => !evidenceIds.has(id));
        if (invalidRefs.length) warnings.push(`비교항목 ${index + 1}: 존재하지 않는 근거 ID ${invalidRefs.join(', ')}`);
        item.evidence_ids = refs.filter(id => evidenceIds.has(id));
        const linkedRisk = riskById.get(item.risk_id);
        if (linkedRisk) item.risk = normalizeRiskGrade(linkedRisk.grade);
        else {
          warnings.push(`비교항목 ${index + 1}: 연결된 risk_id ${item.risk_id || '없음'}를 위험 원장에서 찾지 못해 보완권고로 격리했습니다.`);
          item.risk = '보완권고';
        }
      });
      array(result.performance_metrics).forEach(metric => {
        const linkedRisk = riskById.get(metric.risk_id);
        if (linkedRisk) metric.risk = normalizeRiskGrade(linkedRisk.grade);
      });
      state.semanticWarnings = warnings;
      state.actionItems = array(result.risks).filter(risk => ['즉시확인','조치필요'].includes(normalizeRiskGrade(risk.grade))).map((risk,index) => ({
        action_id:`A-${String(index + 1).padStart(3,'0')}`,
        risk_id:risk.risk_id,
        grade:normalizeRiskGrade(risk.grade),
        title:risk.title,
        question:risk.question,
        required_documents:array(risk.required_documents).join(' · '),
        evidence_ids:array(risk.evidence_ids),
        owner:'', due_date:'', status:'미요청', memo:''
      }));
      state.actionsDirty = false;
    }

