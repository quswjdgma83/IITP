    const fileExtension = (name) => String(name).split('.').pop().toLowerCase();
    const bytes = (size) => size < 1024 * 1024 ? `${(size / 1024).toFixed(1)}KB` : `${(size / 1024 / 1024).toFixed(1)}MB`;
