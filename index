- 원문 사실, 계산 결과, 분석 의견, 사용자 결정을 구분하십시오.
- 공식 평가등급·규정 위반·제재를 판정하지 마십시오.
- 내부 추론과 사고과정은 출력하지 말고, 검증 가능한 주장·근거·영향·권고·수용시험만 반환하십시오.

[사용자 기준선 결정]
${JSON.stringify(state.baselineDecision)}

[문서별 사실 원장]
${JSON.stringify(agentDocumentLedger(extractedDocuments))}`;
      return {model:settings.model,store:false,reasoning:{effort:settings.reasoning},max_output_tokens:Math.min(12000,settings.maxOutputTokens),text:{verbosity:'medium',format:{type:'json_schema',name:`rnd_${role}_review`,strict:true,schema:AGENT_REVIEW_SCHEMA}},input:[{role:'system',content:[{type:'input_text',text:'당신은 국가연구개발 문서의 독립 검토자입니다. 문서 원장에 없는 사실을 만들지 말고 지정된 역할 범위와 JSON 스키마를 지키십시오.'}]},{role:'user',content:[{type:'input_text',text:prompt}]}]};
    }

    function buildCriticRequest(settings,management,comparison,extractedDocuments) {
      const prompt = `당신은 비판적 검증자입니다. 두 독립 전문가의 결과를 상호 검증하여 과도한 판정, 근거 없는 주장, 기준선 오인, 지표 방향·단위·조건 오류와 상충 의견을 판정하십시오.
- issue_id는 D-001 형식으로 부여하십시오.
- verdict는 채택, 조건부 채택, 기각, 판단보류 중 하나만 사용하십시오. 이는 두 전문가의 합의가 아니라 비판적 검증자의 중재 판정입니다.
- 단순 다수결을 하지 말고 담당영역의 근거와 사람 확인 필요성을 우선하십시오.
- 두 전문가의 모든 finding_id를 정확히 한 번씩 decisions에 포함하여 채택·조건부 채택·기각·판단보류 중 하나로 판정하십시오.
- 새로운 사실이나 수치를 만들지 말고, 원 검토의 finding_id와 evidence_ids만 참조하십시오.
- 내부 사고과정은 출력하지 말고 제안·반론·판정·근거·최종 지시만 반환하십시오.

[기준선]
${JSON.stringify(state.baselineDecision)}
[R&D 사업관리 검토]
${JSON.stringify(management)}
[계획·보고서 비교 검토]
${JSON.stringify(comparison)}
[검토자가 인용을 대조할 문서 근거 원장]
${JSON.stringify(agentEvidenceLedger(extractedDocuments))}`;
      return {model:settings.model,store:false,reasoning:{effort:settings.reasoning},max_output_tokens:Math.min(10000,settings.maxOutputTokens),text:{verbosity:'medium',format:{type:'json_schema',name:'rnd_critical_review',strict:true,schema:CRITIC_REVIEW_SCHEMA}},input:[{role:'system',content:[{type:'input_text',text:'당신은 독립 검토 결과의 중재자입니다. 숨은 추론은 출력하지 않고 검증 가능한 판정 기록만 생성합니다.'}]},{role:'user',content:[{type:'input_text',text:prompt}]}]};
    }

    function buildAdjudicatedLedger(management,comparison,critic) {
      const findingMap = new Map([...array(management?.findings),...array(comparison?.findings)].map(item => [item.finding_id,item]));
      const accepted = [], unresolved = [], rejected = [];
      array(critic?.decisions).forEach(decision => {
        const findings = [...array(decision.management_finding_ids),...array(decision.comparison_finding_ids)].map(id => findingMap.get(id)).filter(Boolean);
        const record = {issue_id:decision.issue_id,topic:decision.topic,verdict:decision.verdict,reason_summary:decision.reason_summary,final_instruction:decision.final_instruction,human_confirmation_required:decision.human_confirmation_required,evidence_ids:decision.evidence_ids,findings};
        if (['채택','조건부 채택'].includes(decision.verdict)) accepted.push(record);
        else if (decision.verdict === '기각') rejected.push(record);
        else unresolved.push(record);
      });
      return {accepted,unresolved,rejected,required_checks:array(critic?.required_checks),limitations:array(critic?.limitations)};
    }

    function enforceAdjudicationVisibility(result,ledger) {
      result.questions = array(result.questions);
      result.limitations = array(result.limitations);
      [...array(ledger.unresolved),...array(ledger.accepted).filter(item => item.human_confirmation_required || item.verdict === '조건부 채택')].forEach(item => {
        const question = `협업검증 ${item.issue_id} · 사람 확인 필요: ${item.final_instruction || item.topic}`;
        if (!result.questions.includes(question)) result.questions.push(question);
      });
      array(ledger.rejected).forEach(item => {
        const note = `협업검증 ${item.issue_id} · 기각된 주장은 최종 판단에서 제외: ${item.topic}`;
        if (!result.limitations.includes(note)) result.limitations.push(note);
      });
      array(ledger.required_checks).forEach(check => {
        const note = `협업검증 필수 확인: ${check}`;
        if (!result.limitations.includes(note)) result.limitations.push(note);
      });
      return result;
    }

    function buildFinalEditorRequest(settings,extractedDocuments,adjudicatedLedger) {
      const prompt = `${buildUserPrompt(settings)}

당신은 최종 편집자입니다. 문서 사실 원장과 브라우저가 비판적 검증 판정에 따라 만든 승인 원장을 바탕으로 기존 R&D 내부검토 대시보드 스키마를 완성하십시오.
- accepted 항목만 분석 판단의 입력으로 사용하십시오. rejected 항목의 주장은 최종 판정에 사용하지 마십시오.
- unresolved와 사람 확인 필요 항목은 questions·limitations에 판단 곤란 또는 확인 필요로 표시하고 숨기지 마십시오.
- 새로운 사실·수치·근거를 만들지 말고, 최종 evidence_index에 E-001 형식의 ID를 부여해 모든 판단을 연결하십시오.
- 비교 기준선은 최초 입력된 연구개발계획서를 기본으로 적용하되, 이를 협약변경 승인이나 공식 확정으로 표현하지 마십시오.
- risks를 검토등급의 단일 원장으로 사용하고 최종 결과는 지정된 JSON 스키마만 반환하십시오.

[기준선]
${JSON.stringify(state.baselineDecision)}
[문서별 사실 원장]
${JSON.stringify(agentDocumentLedger(extractedDocuments))}
[브라우저 결정론적 승인 원장]
${JSON.stringify(adjudicatedLedger)}`;
      return {model:settings.model,store:false,reasoning:{effort:settings.reasoning},max_output_tokens:settings.maxOutputTokens,text:{verbosity:'medium',format:{type:'json_schema',name:'rnd_multi_agent_final',strict:true,schema:OUTPUT_SCHEMA}},input:[{role:'system',content:[{type:'input_text',text:SYSTEM_PROMPT}]},{role:'user',content:[{type:'input_text',text:prompt}]}]};
    }

    function validateAgentEvidenceRefs(items,extractedDocuments) {
      const normalizePage = value => String(value || '').toLowerCase().replace(/page|페이지|p\.?|쪽|면|\s/g,'');
      const ledgers = new Map(agentEvidenceLedger(extractedDocuments).map(item => [item.document_id,new Set(item.locations.flatMap(location => [normalizePage(location.page),normalizePage(location.printed_page)]).filter(Boolean))]));
      const pageNumbers = value => {
        const normalized = normalizePage(value).replace(/[–—-]/g,'~');
        const numbers = (normalized.match(/\d+/g) || []).map(Number).filter(Number.isFinite);
        if (normalized.includes('~') && numbers.length >= 2) {
          const start = Math.min(numbers[0],numbers[1]), end = Math.max(numbers[0],numbers[1]);
          return new Set(Array.from({length:Math.min(500,end - start + 1)},(_,index) => start + index));
        }
        return new Set(numbers);
      };
      const pageMatches = (requested,knownPages) => {
        const requestedNumbers = pageNumbers(requested);
        if (!requestedNumbers.size || !knownPages.size) return true;
        return [...knownPages].some(known => [...pageNumbers(known)].some(page => requestedNumbers.has(page)));
      };
      const warnings = array(items).flatMap(item => array(item.evidence_ids).flatMap(ref => {
        const [documentId,page] = String(ref).split('|');
        if (!ledgers.has(documentId)) return [`전문역할 근거 문서 ID 확인 필요: ${ref}`];
        const knownPages = ledgers.get(documentId);
        return pageMatches(page,knownPages) ? [] : [`전문역할 근거 페이지 대조 필요: ${ref}`];
      }));
      state.agentReferenceWarnings = [...new Set([...state.agentReferenceWarnings,...warnings])];
      return warnings;
    }

    function validateSpecialistReview(review,prefix,extractedDocuments) {
      const ids = array(review?.findings).map(item => String(item.finding_id || '').trim());
      if (ids.some(id => !new RegExp(`^${prefix}-\\d{3,}$`).test(id))) throw new Error(`${prefix} 전문가 결과의 finding_id 형식이 올바르지 않습니다.`);
      if (new Set(ids).size !== ids.length) throw new Error(`${prefix} 전문가 결과의 finding_id가 중복되었습니다.`);
      validateAgentEvidenceRefs(review?.findings,extractedDocuments);
    }

    function validateCriticReview(review,management,comparison,extractedDocuments) {
      const decisions = array(review?.decisions);
      const ids = decisions.map(item => String(item.issue_id || '').trim());
      if (ids.some(id => !/^D-\d{3,}$/.test(id))) throw new Error('비판적 검증 결과의 issue_id 형식이 올바르지 않습니다.');
      if (new Set(ids).size !== ids.length) throw new Error('비판적 검증 결과의 issue_id가 중복되었습니다.');
      const managementIds = new Set(array(management?.findings).map(item => item.finding_id));
      const comparisonIds = new Set(array(comparison?.findings).map(item => item.finding_id));
      const invalid = decisions.flatMap(item => [...array(item.management_finding_ids).filter(id => !managementIds.has(id)),...array(item.comparison_finding_ids).filter(id => !comparisonIds.has(id))]);
      if (invalid.length) throw new Error(`비판적 검증이 존재하지 않는 finding_id를 참조했습니다: ${[...new Set(invalid)].join(', ')}`);
      const counts = new Map([...managementIds,...comparisonIds].map(id => [id,0]));
      decisions.forEach(item => [...array(item.management_finding_ids),...array(item.comparison_finding_ids)].forEach(id => counts.set(id,(counts.get(id)||0)+1)));
      const uncovered = [...counts].filter(([,count]) => count !== 1).map(([id]) => id);
      if (uncovered.length) throw new Error(`비판적 검증은 모든 finding_id를 정확히 한 번 판정해야 합니다: ${uncovered.join(', ')}`);
      validateAgentEvidenceRefs(decisions,extractedDocuments);
    }

    async function executeAgentStage(role,label,requestBody,settings,context,validator=null) {
      const activeCopy = {
        management:'첫 계획서를 기준으로 일정·역할·예산·후속조치를 대조하고 있습니다.',
        comparison:'계획과 실적의 목표값·조건·일정 변동을 연결하고 있습니다.',
        critic:'두 독립 검토의 근거와 상충 주장을 중재하고 있습니다.',
        editor:'채택·기각·보류 판정을 최종 결과에 반영하고 있습니다.'
      };
      setAgentCard(role,'active','검토 중',activeCopy[role]);
      $('#processDescription').textContent = `${label}가 구조화된 검토 결과를 작성하고 있습니다.`;
      try {
        const cached = state.agentCheckpoints[role];
        let result;
        if (cached) {
          result = {parsed:cached.parsed,data:{usage:cached.usage || {}}};
        } else {
          result = await sendWithLimitedRetry(requestBody,settings,context);
        }
        if (validator) validator(result.parsed);
        if (!cached) state.agentCheckpoints[role] = {parsed:result.parsed,usage:result.data?.usage || {}};
        const auditOutput = role === 'editor' ? {summary:'비판적 검증 판정을 반영한 최종 대시보드 JSON 생성 완료'} : result.parsed;
        state.agentRuns.push({role,label,status:'완료',completed_at:new Date().toISOString(),output:auditOutput});
        const count = array(result.parsed.findings).length || array(result.parsed.decisions).length;
        const summary = role === 'editor' ? auditOutput.summary : result.parsed.summary;
        setAgentCard(role,'done',role === 'editor' ? '생성 완료' : `${count.toLocaleString('ko-KR')}건 완료`,summary);
        return result.parsed;
      } catch (error) {
        setAgentCard(role,'error','실패',`검토 중 오류 · ${sanitizeDiagnosticValue(error.message || '알 수 없는 오류')}`);
        state.agentRuns.push({role,label,status:'실패',completed_at:new Date().toISOString(),error:sanitizeDiagnosticValue(error.message || '알 수 없는 오류')});
        throw error;
      }
    }

    async function runMultiAgentAnalysis(settings,extractedDocuments,files) {
      const agentSignature = `${state.checkpointSignature}|${JSON.stringify(state.baselineDecision)}`;
      if (state.agentCheckpointSignature !== agentSignature) {
        state.agentCheckpoints = {};
        state.agentCheckpointSignature = agentSignature;
      }
      setProcessStep(3,'active','1/4');
      const common = {endpoint:'POST /v1/responses',pipeline_mode:'multi_agent',model:settings.model,reasoning_effort:settings.reasoning,pdf_detail:'해당 없음',document_count:files.length,total_file_bytes:files.reduce((sum,file)=>sum+file.size,0)};
      let management, comparison, managementError, comparisonError;
      try {
        management = await executeAgentStage('management','R&D 사업관리 전문가',buildSpecialistRequest(settings,'management',extractedDocuments),settings,{...common,pipeline_stage:'agent_management',max_output_tokens:Math.min(12000,settings.maxOutputTokens)},review => validateSpecialistReview(review,'MGT',extractedDocuments));
      } catch (error) {
        managementError = error;
        management = {role:'R&D 사업관리 전문가',summary:'실행 실패로 검토 결과 없음',findings:[],questions:[],limitations:[sanitizeDiagnosticValue(error.message || '실행 실패')]};
      }
      setProcessStep(3,'active','2/4');
      try {
        comparison = await executeAgentStage('comparison','계획·보고서 비교분석 전문가',buildSpecialistRequest(settings,'comparison',extractedDocuments),settings,{...common,pipeline_stage:'agent_comparison',max_output_tokens:Math.min(12000,settings.maxOutputTokens)},review => validateSpecialistReview(review,'CMP',extractedDocuments));
      } catch (error) {
        comparisonError = error;
        comparison = {role:'계획·보고서 비교분석 전문가',summary:'실행 실패로 검토 결과 없음',findings:[],questions:[],limitations:[sanitizeDiagnosticValue(error.message || '실행 실패')]};
      }
      if (managementError && comparisonError) throw managementError;
      setProcessStep(3,'active','3/4');
      const critic = await executeAgentStage('critic','비판적 검증자',buildCriticRequest(settings,management,comparison,extractedDocuments),settings,{...common,pipeline_stage:'agent_critic',max_output_tokens:Math.min(10000,settings.maxOutputTokens)},review => validateCriticReview(review,management,comparison,extractedDocuments));
      setProcessStep(3,'active','4/4');
      const adjudicatedLedger = buildAdjudicatedLedger(management,comparison,critic);
      const final = await executeAgentStage('editor','최종 편집자',buildFinalEditorRequest(settings,extractedDocuments,adjudicatedLedger),settings,{...common,pipeline_stage:'agent_final_editor',max_output_tokens:settings.maxOutputTokens},result => validateResultShape(enforceAdjudicationVisibility(result,adjudicatedLedger)));
      state.agentAudit = {mode:'2개 독립검토 + 비판중재 + 최종편집',management,comparison,critic,adjudicated_ledger:adjudicatedLedger,completed_at:new Date().toISOString()};
      return final;
    }

    function baselineCandidates(extractedDocuments) {
      const files = [state.planFile,...state.comparisonFiles];
      const seenGroups = new Set();
      return extractedDocuments.map((document,index) => ({document,index})).filter(({document,index}) => {
        const profile = documentProfile(files[index], index === 0 ? 'plan' : 'comparison', index);
        if (!['원계획','승인 변경계획'].includes(profile.role) || seenGroups.has(profile.logical_group)) return false;
        seenGroups.add(profile.logical_group);
        return true;
      });
    }

    function needsBaselineReview(extractedDocuments) {
      const candidates = baselineCandidates(extractedDocuments);
      const uncertainChange = extractedDocuments.some(document => array(document?.changes).some(change => !/승인 확인|승인됨|비대상/.test(change.approval_status || '')));
      return candidates.length > 1 || uncertainChange;
    }

    function requestBaselineReview(extractedDocuments, files) {
      const profile = documentProfile(files[0], 'plan', 0);
      state.baselineDecision = {
        document_id:profile.document_id,
        role:profile.role,
        status:'첫 입력 연구개발계획서 자동 적용',
        source:'default_first_document',
        approval_verified:false,
        approval_evidence:''
      };
      return Promise.resolve(state.baselineDecision);
    }

    function extractOutputText(response) {
      if (typeof response.output_text === 'string' && response.output_text.trim()) return response.output_text;
      const chunks = [];
      array(response.output).forEach(item => array(item.content).forEach(content => {
        if (content.type === 'output_text' && typeof content.text === 'string') chunks.push(content.text);
      }));
      return chunks.join('');
    }

    function extractRefusal(response) {
      for (const item of array(response?.output)) {
        for (const content of array(item?.content)) {
          if (content?.type === 'refusal' && content?.refusal) return String(content.refusal);
        }
      }
      return '';
    }

    function summarizeApiResponse(response, data, outputText = '') {
      const usage = data?.usage || {};
      const outputDetails = usage?.output_tokens_details || {};
      return {
        http_status: response?.status || null,
        response_id: sanitizeDiagnosticValue(data?.id || ''),
        status: data?.status || '',
        incomplete_reason: data?.incomplete_details?.reason || '',
        output_item_types: array(data?.output).map(item => item?.type || 'unknown'),
        content_item_types: array(data?.output).flatMap(item => array(item?.content).map(content => content?.type || 'unknown')),
        output_text_characters: outputText.length,
        usage: {
          input_tokens: usage?.input_tokens ?? null,
          output_tokens: usage?.output_tokens ?? null,
          reasoning_tokens: outputDetails?.reasoning_tokens ?? null,
          total_tokens: usage?.total_tokens ?? null
        }
      };
    }

    function responseProcessingError(code, message, response, data, context, outputText = '') {
      const error = new Error(message);
      error.status = response?.status || 200;
      error.type = 'response_processing_error';
      error.code = code;
      error.param = '';
      error.headers = collectResponseHeaders(response);
      error.requestId = error.headers['x-request-id'] || data?._request_id || '';
      error.clientRequestId = context?.client_request_id || '';
      error.context = context || {};
      error.responseMeta = summarizeApiResponse(response, data, outputText);
      return error;
    }

    function normalizeStructuredOutput(text) {
      const trimmed = String(text || '').trim();
      return trimmed.replace(/^```(?:json)?\s*/i, '').replace(/\s*```$/i, '').trim();
    }

    function emptyPipelineUsage() {
      return {input_tokens:0, output_tokens:0, total_tokens:0, reasoning_tokens:0, request_count:0, attempted_request_count:0};
    }

    function addPipelineUsage(aggregate, usage) {
      const details = usage?.output_tokens_details || {};
      aggregate.input_tokens += Number(usage?.input_tokens || 0);
      aggregate.output_tokens += Number(usage?.output_tokens || 0);
      aggregate.total_tokens += Number(usage?.total_tokens || 0);
      aggregate.reasoning_tokens += Number(details?.reasoning_tokens || 0);
      aggregate.request_count += 1;
    }

    async function sendStructuredRequest(requestBody, settings, context) {
      const requestJson = JSON.stringify(requestBody);
      const clientRequestId = createClientRequestId('rnd-analysis');
      context.encoded_request_bytes = new Blob([requestJson]).size;
      context.client_request_id = clientRequestId;
      context.started_at = new Date().toISOString();
      state.lastRequestMeta = context;
      if (state.pipelineUsage) state.pipelineUsage.attempted_request_count += 1;
      const response = await fetch('https://api.openai.com/v1/responses', {
        method:'POST',
        headers:{'Content-Type':'application/json',Authorization:`Bearer ${settings.apiKey}`,'X-Client-Request-Id':clientRequestId},
        body:requestJson,
        signal:state.controller.signal,
        cache:'no-store'
      });
      const data = await response.json().catch(() => ({}));
      if (!response.ok) throw apiError(response, data, context);
      const outputText = extractOutputText(data);
      const refusal = extractRefusal(data);
      if (data.status === 'incomplete') {
        const reason = data?.incomplete_details?.reason || 'unknown';
        throw responseProcessingError(reason, `응답이 완료되지 않았습니다. incomplete_details.reason=${reason}`, response, data, context, outputText);
      }
      if (data.status && data.status !== 'completed') throw responseProcessingError('incomplete_response', `응답 상태가 completed가 아닙니다: ${data.status}`, response, data, context, outputText);
      if (refusal) throw responseProcessingError('model_refusal', `모델이 요청을 거절했습니다: ${refusal}`, response, data, context, outputText);
      if (!outputText) throw responseProcessingError('structured_output_missing', 'API 응답에서 분석 JSON을 찾지 못했습니다.', response, data, context, outputText);
      let parsed;
      try { parsed = JSON.parse(normalizeStructuredOutput(outputText)); }
      catch (parseError) {
        throw responseProcessingError('structured_output_parse', `Structured Output JSON 파싱 실패: ${parseError.message}`, response, data, context, outputText);
      }
      addPipelineUsage(state.pipelineUsage, data.usage);
      return {parsed, data};
    }

    function retryDelayMs(error, attempt) {
      const retryAfter = error?.headers?.['retry-after'];
      const seconds = Number(retryAfter);
      if (Number.isFinite(seconds) && seconds > 0) return seconds * 1000;
      const asDate = Date.parse(retryAfter || '');
      if (Number.isFinite(asDate)) return Math.max(asDate - Date.now(), 1000);
      const reset = String(error?.headers?.['x-ratelimit-reset-tokens'] || error?.headers?.['x-ratelimit-reset-requests'] || '');
      const resetMatch = reset.match(/(?:(\d+(?:\.\d+)?)m)?(?:(\d+(?:\.\d+)?)s)?/);
      if (resetMatch && (resetMatch[1] || resetMatch[2])) return (Number(resetMatch[1] || 0) * 60 + Number(resetMatch[2] || 0)) * 1000;
      return Math.min(2000 * (2 ** attempt) + Math.floor(Math.random() * 700), 30000);
    }

    function abortableDelay(ms) {
      return new Promise((resolve, reject) => {
        const timer = setTimeout(resolve, ms);
        state.controller?.signal.addEventListener('abort', () => {
          clearTimeout(timer);
          reject(new DOMException('Aborted','AbortError'));
        }, {once:true});
      });
    }

    async function sendWithLimitedRetry(requestBody, settings, context, maxRetries = 2) {
      let attempt = 0;
      while (true) {
        try { return await sendStructuredRequest(requestBody, settings, {...context, retry_attempt:attempt}); }
        catch (error) {
          const classification = classifyApiError(error);
          const message = String(error?.message || '');
          const requested = Number(message.match(/requested\s+(\d+)/i)?.[1]);
          const limit = Number(message.match(/limit\s+(\d+)/i)?.[1]);
          const oversizedTokenRequest = classification === 'token_rate_limit' && Number.isFinite(requested) && Number.isFinite(limit) && requested > limit;
          const retryable = !oversizedTokenRequest && ['token_rate_limit','request_rate_limit','rate_limit','openai_server','network_or_cors'].includes(classification);
          if (!retryable || attempt >= maxRetries) throw error;
          const delay = retryDelayMs(error, attempt);
          if (delay > 60000) {
            error.message = `${error.message} 자동 재시도까지 ${Math.ceil(delay / 1000)}초가 필요하므로 요청을 멈췄습니다. reset 이후 다시 시도하면 완료된 문서 체크포인트를 재사용합니다.`;
            throw error;
          }
          $('#processDescription').textContent = `일시적 오류로 ${Math.ceil(delay / 1000)}초 후 재시도합니다 · ${attempt + 1}/${maxRetries}`;
          await abortableDelay(delay);
          attempt += 1;
        }
      }
    }

    function analysisSignature(settings, files) {
      return JSON.stringify({model:settings.model,pdfDetail:settings.pdfDetail,reviewMemo:settings.reviewMemo,analysisDate:settings.analysisDate,maxOutputTokens:settings.maxOutputTokens,usePoint:settings.usePoint,purposes:settings.purposes,analysisMode:settings.analysisMode,files:files.map(file => ({key:fileKey(file),hash:state.fileHashes[fileKey(file)],profile:documentProfile(file, file === state.planFile ? 'plan' : 'comparison')}))});
    }

