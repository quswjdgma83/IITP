            <div class="diagnostic-field"><span>Base64 포함 요청 크기</span><code>${e(request.encoded_request_bytes ? bytes(request.encoded_request_bytes) : '—')}</code></div>
            <div class="diagnostic-field"><span>retry/reset</span><code>${e(diagnostic.response_headers['retry-after'] || diagnostic.response_headers['x-ratelimit-reset-tokens'] || diagnostic.response_headers['x-ratelimit-reset-requests'] || '헤더 없음')}</code></div>
            <div class="diagnostic-field"><span>Responses status</span><code>${e(responseSummary.status || '확인되지 않음')}</code></div>
            <div class="diagnostic-field"><span>incomplete reason</span><code>${e(responseSummary.incomplete_reason || '없음')}</code></div>
            <div class="diagnostic-field"><span>응답 ID</span><code>${e(responseSummary.response_id || '없음')}</code></div>
            <div class="diagnostic-field"><span>입력 토큰</span><code>${e(usage.input_tokens ?? '확인되지 않음')}</code></div>
            <div class="diagnostic-field"><span>출력 / 추론 토큰</span><code>${e(usage.output_tokens ?? '—')} / ${e(usage.reasoning_tokens ?? '—')}</code></div>
            <div class="diagnostic-field"><span>부분 출력 길이</span><code>${e(responseSummary.output_text_characters ?? '—')}자</code></div>
          </div>
          <pre class="diagnostic-code" id="diagnosticCode">${e(diagnosticText)}</pre>
          <div class="diagnostic-actions">
            <button class="btn btn-small" type="button" id="copyDiagnostic">진단정보 복사</button>
            <button class="btn btn-small" type="button" id="downloadDiagnostic">진단 JSON 저장</button>
          </div>
        </details>`;
      $('#processError').classList.remove('hidden');
      $('#cancelAnalysis').classList.add('hidden');
      $('#retryAnalysis').classList.remove('hidden');
      $('#backToInput').disabled = false;
      $('#copyDiagnostic').addEventListener('click', copyDiagnostic);
      $('#downloadDiagnostic').addEventListener('click', downloadDiagnostic);
    }

    async function copyDiagnostic() {
      return copyDiagnosticPayload($('#copyDiagnostic'));
    }

    async function copyDiagnosticPayload(button) {
      if (!state.diagnostic) return;
      const diagnosticText = JSON.stringify(state.diagnostic, null, 2);
      try {
        await navigator.clipboard.writeText(diagnosticText);
      } catch {
        const textarea = document.createElement('textarea');
        textarea.value = diagnosticText;
        textarea.style.position = 'fixed';
        textarea.style.opacity = '0';
        document.body.appendChild(textarea);
        textarea.select();
        document.execCommand('copy');
        textarea.remove();
      }
      if (button) {
        const previous = button.textContent;
        button.textContent = '복사됨';
        setTimeout(() => { button.textContent = previous; }, 1400);
      }
    }

    function downloadDiagnostic() {
      if (!state.diagnostic) return;
      const blob = new Blob([JSON.stringify(state.diagnostic, null, 2)], {type:'application/json'});
      const url = URL.createObjectURL(blob);
      const anchor = document.createElement('a');
      anchor.href = url;
      anchor.download = `rnd-api-diagnostic-${new Date().toISOString().replace(/[:.]/g,'-')}.json`;
      anchor.click();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
    }

    function normalizeRiskGrade(value) {
      const text = String(value || '').trim();
      const upper = text.toUpperCase();
      if (upper.includes('P1') || text.includes('즉시 확인') || text.includes('즉시확인')) return '즉시확인';
      if (upper.includes('P2') || text.includes('조치 필요') || text.includes('조치필요')) return '조치필요';
      if (upper.includes('P3') || text.includes('보완 권고') || text.includes('보완권고')) return '보완권고';
      if (upper.includes('P4') || text.includes('모니터링') || text.includes('정상')) return '정상';
      return text;
    }

    function riskGradeKey(value) {
      return {'즉시확인':'critical','조치필요':'action','보완권고':'advisory','정상':'watch'}[normalizeRiskGrade(value)] || 'neutral';
    }

    function tagClass(value) {
      const normalizedRisk = normalizeRiskGrade(value);
      const riskClass = {'즉시확인':'tag-critical','조치필요':'tag-action','보완권고':'tag-advisory','정상':'tag-watch'}[normalizedRisk];
      if (riskClass) return riskClass;
      const text = String(value || '').toUpperCase();
      if (/초과|달성|완료/.test(text) && !/미달|부분/.test(text)) return text.includes('초과') ? 'tag-exceed' : 'tag-done';
      if (/미달|미완료|실패|중대한\s*지연/.test(text)) return 'tag-miss';
      if (/부분/.test(text)) return 'tag-partial';
      if (/변경/.test(text)) return 'tag-change';
      if (/지연|누락|불일치|곤란|확인|불명|미도래/.test(text)) return 'tag-unclear';
      return 'tag-neutral';
    }
    const tag = value => {
      const normalized = normalizeRiskGrade(value);
      return `<span class="tag ${tagClass(value)}">${e(textOrUnknown(normalized))}</span>`;
    };

    function metricBarState(metric) {
      const status = String(metric && metric.achievement_status || '').trim();
      if (/초과\s*달성|달성\s*완료|완료|달성/.test(status) && !/부분|미달|미완료/.test(status)) {
        return {width:100, className:'bar-achieved', label:status || '달성'};
      }
      if (/부분/.test(status)) return {width:62, className:'bar-partial', label:status || '부분 달성'};
      if (/미달|미완료|실패/.test(status)) return {width:28, className:'bar-missed', label:status || '미달'};
      if (/미도래/.test(status)) return {width:8, className:'bar-pending', label:status || '기한 미도래'};
      return {width:14, className:'bar-unclear', label:status || '판단 곤란'};
    }

    function attentionKey(statusValue,riskValue) {
      const status = String(statusValue || '').trim();
      const risk = normalizeRiskGrade(riskValue);
      if (risk === '즉시확인' || /미달|미달성|미완료|실패|중대한\s*지연/.test(status)) return 'urgent';
      if (risk === '조치필요' || /부분|미도래|판단\s*곤란|확인|불명|불일치|지연|변경/.test(status)) return 'review';
      if (risk === '보완권고') return 'info';
      if (risk === '정상' || /초과\s*달성|달성|완료|정상/.test(status)) return 'normal';
      return 'review';
    }

    function emphasizeText(value) {
      let safe = e(textOrUnknown(value));
      safe = safe.replace(/(즉시확인|목표 대비 미달|미달|중대한 지연)/g, '<span class="inline-emphasis danger">$1</span>');
      safe = safe.replace(/(조치필요|부분 달성|일정 지연|정보 불일치|증빙 부족|확인 필요|변경 승인 여부)/g, '<span class="inline-emphasis">$1</span>');
      safe = safe.replace(/(보완권고|계획 변경|대응관계 확인)/g, '<span class="inline-emphasis info">$1</span>');
      safe = safe.replace(/(정상|초과 달성|달성 완료)/g, '<span class="inline-emphasis good">$1</span>');
      safe = safe.replace(/(\d[\d,.]*\s*%)/g, '<strong class="key-number">$1</strong>');
      return safe;
    }
    const listHtml = items => array(items).length ? `<ul class="bullet-list">${array(items).map(item => `<li>${emphasizeText(item)}</li>`).join('')}</ul>` : '<div class="empty">문서에서 확인되지 않음</div>';
    const empty = message => `<div class="empty">${e(message)}</div>`;
    const evidenceRefs = ids => array(ids).length ? `<span>${array(ids).map(id => `<button class="evidence-link" type="button" data-evidence-ref="${e(id)}">${e(id)}</button>`).join(' ')}</span>` : '<span class="metric-sub">근거 ID 없음</span>';
    function agentEvidenceRefs(refs) {
      const normalizePage = value => String(value || '').toLowerCase().replace(/page|페이지|p\.?|쪽|면|\s/g,'');
      return array(refs).map(ref => {
        const [documentId,page] = String(ref).split('|');
        const match = array(state.result?.evidence_index).find(item => item.document_id === documentId && (!normalizePage(page) || [item.page,item.printed_page].some(value => normalizePage(value) === normalizePage(page))));
        return match ? evidenceRefs([match.evidence_id]) : `<span class="tag tag-unclear">${e(ref)} · 근거 확인 필요</span>`;
      }).join(' ') || '<span class="metric-sub">근거 연결 없음</span>';
    }

    function renderOutput(result, settings) {
      const meta = result.metadata || {};
      const metrics = array(result.performance_metrics);
      const riskOrder = {'즉시확인':0,'조치필요':1,'보완권고':2,'정상':3};
      const risks = array(result.risks).map(risk => ({...risk,grade:normalizeRiskGrade(risk.grade)})).sort((a,b) => (riskOrder[a.grade] ?? 9) - (riskOrder[b.grade] ?? 9));
      const comparisons = array(result.comparisons);
      const gradedItems = risks.map(item => normalizeRiskGrade(item.grade));
      const urgent = gradedItems.filter(grade => grade === '즉시확인').length;
      const delays = comparisons.filter(c => /지연/.test(c.schedule_status || '')).length + array(result.timeline).filter(t => /지연/.test(t.status || '')).length;
      state.auditMeta = {
        app_version:'v-10', analyzed_at:new Date().toISOString(), model:settings.model, reasoning_effort:settings.reasoning,
        use_point:settings.usePoint, purposes:settings.purposes, processing_strategy:settings.resolvedStrategy || settings.analysisStrategy, analysis_mode:settings.analysisMode,
        document_manifest:[state.planFile,...state.comparisonFiles].filter(Boolean).map((file,index) => ({...documentProfile(file,index===0?'plan':'comparison',index),size_bytes:file.size,extension:fileExtension(file.name),sha256:state.fileHashes[fileKey(file)] || '미산출'})),
        request_count:state.pipelineUsage?.request_count || 0,
        attempted_request_count:state.pipelineUsage?.attempted_request_count || 0,
        validation_warning_count:state.semanticWarnings.length,
        checkpoint_count:state.checkpoints.filter(Boolean).length,
        baseline_decision:state.baselineDecision,
        reviewer_status:'검토자 확인 전', agent_run_summary:state.agentRuns.map(run => ({role:run.role,label:run.label,status:run.status,completed_at:run.completed_at}))
      };
      $('#outputProjectName').textContent = textOrUnknown(meta.project_name);
      const usage = state.responseUsage ? ` · API ${Number(state.responseUsage.request_count || 1).toLocaleString('ko-KR')}회 · 토큰 ${Number(state.responseUsage.total_tokens || 0).toLocaleString('ko-KR')}` : '';
      $('#outputMeta').textContent = `${settings.model} · ${textOrUnknown(meta.usage_point || settings.usePoint)} · 기준일 ${textOrUnknown(meta.analysis_date || settings.analysisDate)}${usage}`;
      const baselineConfirmed = state.baselineDecision?.approval_verified === true && Boolean(String(state.baselineDecision?.approval_evidence || '').trim());
      const defaultBaseline = state.baselineDecision?.source === 'default_first_document';
      $('#baselineBanner').classList.toggle('confirmed', baselineConfirmed || defaultBaseline);
      const baselineCopy = defaultBaseline
        ? `${state.baselineDecision.document_id} · ${state.baselineDecision.role} · 최초 입력된 연구개발계획서를 비교 기준으로 자동 적용했습니다. 공식 승인 여부는 별도 확인 대상입니다.`
        : baselineConfirmed
        ? `${state.baselineDecision.document_id} · ${state.baselineDecision.role} · 확인근거 ${state.baselineDecision.approval_evidence}`
        : `${state.baselineDecision?.document_id || '기준문서'} · 원문 승인·원계획 근거를 검토자가 확인하기 전에는 확정하지 않습니다.`;
      const baselineTitle = defaultBaseline ? '입력 기준선 · 첫 계획서' : (baselineConfirmed ? '검토자 확인 기준선' : '잠정 기준선 · 확인 필요');
      const baselineBadge = defaultBaseline ? '<span class="decision">자동 적용</span>' : tag(baselineConfirmed ? '정상' : '조치필요');
      $('#baselineBanner').innerHTML = `<div><strong>${baselineTitle}</strong><span>${emphasizeText(baselineCopy)}</span></div>${baselineBadge}`;
      $('#printHeader').textContent = `AI 기반 내부검토 초안 · ${textOrUnknown(meta.project_name)} · ${defaultBaseline ? '첫 입력 계획서 기준' : (baselineConfirmed ? '확정 기준선' : '잠정 기준선')} · 검토자 확인 전`;
      const validationBox = $('#semanticValidation');
      validationBox.classList.toggle('hidden', !state.semanticWarnings.length);
      validationBox.innerHTML = state.semanticWarnings.length ? `<strong>자동 교차검증 ${e(state.semanticWarnings.length)}건</strong> · 모순되거나 근거가 불충분한 항목을 정정·격리했습니다. 상세 내용은 검증 내역에서 확인하세요.` : '';
      $('#kpiGrid').innerHTML = [
        ['성과지표', metrics.length, ''], ['비교항목', comparisons.length, ''], ['검토항목', risks.length, ''], ['즉시확인', urgent, 'red'], ['일정 지연', delays, 'amber']
      ].map(([label,value,cls]) => `<div class="kpi"><div class="kpi-label">${e(label)}</div><div class="kpi-value ${cls}">${e(value)}</div></div>`).join('');
      $('#dashboardVisuals').innerHTML = renderDashboardVisuals(metrics, comparisons, risks);

      $('#outputPanels').innerHTML = [
        renderRisks(risks), renderOverview(result), renderMetrics(metrics), renderComparisons(comparisons), renderActions(), renderDelivery(result), renderEvidence(result), renderVerification()
      ].join('');
      const verificationTab = $('[data-tab="verification"]');
      if (verificationTab) verificationTab.textContent = state.agentAudit ? '협업 검증' : '자동 검증';
      activateTab('risks');
      bindOutputFilters();
      $('#apiKey').value = '';
      setApiState('', '분석 완료 · 키 삭제됨');
    }

    function renderDashboardVisuals(metrics, comparisons, risks) {
      const gradeSource = risks.map(item => normalizeRiskGrade(item.grade));
      const riskRows = [
        ['즉시확인','critical'], ['조치필요','action'], ['보완권고','advisory'], ['정상','watch']
      ].map(([label,key]) => [label,key,gradeSource.filter(grade => grade === label).length]);
      const statusRows = [
        ['달성','complete',item => /달성|완료/.test(item.achievement_status || '') && !/부분|미달/.test(item.achievement_status || '')],
        ['부분 달성','partial',item => /부분/.test(item.achievement_status || '')],
        ['미달','miss',item => /미달/.test(item.achievement_status || '')],
        ['판단 곤란','unclear',item => /곤란|확인|불명|불일치/.test(item.achievement_status || '')],
        ['미도래·비교없음','unclear',item => /미도래|비교 대상 없음/.test(item.achievement_status || '')]
      ].map(([label,key,test]) => [label,key,metrics.filter(test).length]);
      const rows = (items, total) => items.map(([label,key,count]) => `<div class="chart-row"><span class="chart-label">${e(label)}</span><div class="chart-track"><div class="chart-fill ${key}" style="width:${total ? Math.max(count ? 4 : 0, count / total * 100) : 0}%"></div></div><span class="chart-count">${e(count)}</span></div>`).join('');
      return `<section class="dashboard-chart" aria-label="검토등급 분포"><div class="dashboard-chart-head"><h2>검토등급 분포</h2><span>총 ${e(gradeSource.length)}건</span></div>${rows(riskRows,gradeSource.length)}</section>
        <section class="dashboard-chart" aria-label="성과지표 달성 상태"><div class="dashboard-chart-head"><h2>성과지표 달성 상태</h2><span>총 ${e(metrics.length)}건</span></div>${rows(statusRows,metrics.length)}</section>`;
    }

    function renderOverview(result) {
      const m = result.metadata || {}, s = result.summary || {};
      const facts = [
        ['사업명', m.business_name], ['과제번호', m.project_id], ['연구기간', m.period], ['현재 단계·연차', m.current_stage],
        ['분석 기준선', m.baseline_status], ['사용 문서', array(m.source_documents).join(' · ')]
      ];
      return `<section class="tab-panel active" data-panel="overview">
        <div class="overview-grid">
          <div class="section-card">
            <div class="section-card-head"><h2>핵심 요약</h2></div>
            <div class="summary-block"><h3>연구개발 필요성</h3><p>${emphasizeText(s.need)}</p></div>
            <div class="summary-block is-primary"><h3>최종목표</h3><p>${emphasizeText(s.final_goal)}</p></div>
            <div class="summary-block"><h3>핵심 연구내용</h3>${listHtml(s.core_contents)}</div>
            <div class="summary-block"><h3>기대효과</h3>${listHtml(s.expected_effects)}</div>
            <div class="summary-block"><h3>활용계획</h3>${listHtml(s.utilization)}</div>
          </div>
          <div>
            <div class="section-card">
              <div class="section-card-head"><h2>기본 과제정보</h2></div>
              <div class="fact-grid">${facts.map(([label,value]) => `<div class="fact"><div class="fact-label">${e(label)}</div><div class="fact-value">${e(textOrUnknown(value))}</div></div>`).join('')}</div>
            </div>
            <div class="section-card">
              <div class="section-card-head"><h2>기준선 판단</h2></div>
              <p style="margin:0;color:#344054">${emphasizeText(m.baseline_note)}</p>
            </div>
          </div>
        </div>
        <div class="section-card">
          <div class="section-card-head"><h2>기술개발 흐름</h2></div>
          ${array(result.technology_flow).length ? `<div class="flow">${array(result.technology_flow).map(item => `<div class="flow-item"><div class="flow-label">${e(item.label)}</div><div class="flow-text">${e(textOrUnknown(item.text))}</div></div>`).join('')}</div>` : empty('기술개발 흐름을 문서에서 확인하지 못했습니다.')}
        </div>
      </section>`;
    }

    function renderMetrics(metrics) {
      const institutions = [...new Set(metrics.map(item => item.institution).filter(Boolean))];
      return `<section class="tab-panel" data-panel="metrics">
        <div class="section-card">
          <div class="section-card-head"><h2>성과지표</h2><span class="metric-legend"><span><i class="urgent"></i>긴급 판단</span><span><i class="review"></i>확인 필요</span><span><i class="normal"></i>정상·일반</span></span></div>
          <div class="filters">
            <div class="field"><label for="metricSearch">검색</label><input id="metricSearch" type="text" placeholder="지표명·기관·단계"></div>
            <div class="field"><label for="metricInstitution">담당기관</label><select id="metricInstitution"><option value="">전체</option>${institutions.map(value => `<option>${e(value)}</option>`).join('')}</select></div>
            <div class="field"><label for="metricStatus">달성상태</label><select id="metricStatus"><option value="">전체</option>${[...new Set(metrics.map(item => item.achievement_status).filter(Boolean))].map(value => `<option>${e(value)}</option>`).join('')}</select></div>
          </div>
          <div class="metric-list" id="metricList">${metrics.length ? metrics.map(metric => {
            const rate = Number(metric.achievement_rate_value);
            const validRate = metric.calculation_applicable === true && Number.isFinite(rate) && rate >= 0;
            const barState = metricBarState(metric);
            const attention = attentionKey(metric.achievement_status,metric.risk);
            const haystack = [metric.name,metric.institution,metric.stage,metric.achievement_status].join(' ').toLowerCase();
            return `<article class="metric-row metric-${e(attention)}" data-search="${e(haystack)}" data-institution="${e(metric.institution)}" data-status="${e(metric.achievement_status)}">
              <div><div class="metric-name">${e(textOrUnknown(metric.name))}</div><div class="metric-sub">${e([metric.type,metric.stage,metric.institution].filter(Boolean).join(' · '))}</div><div class="metric-sub">방향 ${e(metric.direction || 'unknown')} · ${e(textOrUnknown(metric.measurement_method))}</div></div>
