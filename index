    function downloadResult() {
      if (!state.result) return;
      const name = (state.result.metadata?.project_name || 'rnd-analysis').replace(/[\\/:*?"<>|]/g, '_').slice(0,80);
      const payload = {audit_metadata:state.auditMeta,analysis_result:state.result,multi_agent_review:state.agentAudit,agent_runs:state.agentRuns,follow_up_actions:state.actionItems,semantic_validation:{warnings:state.semanticWarnings}};
      const blob = new Blob([JSON.stringify(payload, null, 2)], {type:'application/json'});
      const url = URL.createObjectURL(blob);
      const anchor = document.createElement('a');
      anchor.href = url;
      anchor.download = `${name}_분석결과.json`;
      anchor.click();
      setTimeout(() => URL.revokeObjectURL(url), 1000);
      state.actionsDirty = false;
    }

