    async function sha256File(file) {
      if (!globalThis.crypto?.subtle) return '지원되지 않음';
      const digest = await crypto.subtle.digest('SHA-256', await file.arrayBuffer());
      return Array.from(new Uint8Array(digest)).map(byte => byte.toString(16).padStart(2,'0')).join('');
    }

    function createClientRequestId(prefix = 'rnd-review') {
      const random = globalThis.crypto && typeof globalThis.crypto.randomUUID === 'function'
        ? globalThis.crypto.randomUUID()
        : `${Date.now()}-${Math.random().toString(16).slice(2)}`;
      return `${prefix}-${random}`;
    }

    function collectResponseHeaders(response) {
      const headers = {};
      if (!response?.headers) return headers;
      DIAGNOSTIC_HEADER_NAMES.forEach(name => {
        const value = response.headers.get(name);
        if (value) headers[name] = value;
      });
      return headers;
    }

    function sanitizeDiagnosticValue(value) {
      let sanitized = String(value ?? '')
        .replace(/sk-[A-Za-z0-9_-]+/g, '[REDACTED_API_KEY]')
        .replace(/\borg-[A-Za-z0-9_-]+\b/g, '[REDACTED_ORG]')
        .replace(/\bproj[_-][A-Za-z0-9_-]+\b/g, '[REDACTED_PROJECT]');
      [state.planFile, ...state.comparisonFiles].filter(Boolean).forEach(file => {
        sanitized = sanitized.split(file.name).join('[REDACTED_FILENAME]');
      });
      return sanitized;
    }

    function classifyApiError(error) {
      const code = String(error?.code || '').toLowerCase();
      const type = String(error?.type || '').toLowerCase();
      const message = String(error?.message || '').toLowerCase();
      if (error?.name === 'AbortError') return 'cancelled';
      if (error instanceof TypeError && /fetch/i.test(error.message || '')) return 'network_or_cors';
      if (error?.code === 'max_output_tokens') return 'output_token_limit';
      if (error?.responseMeta?.status === 'incomplete') return 'incomplete_response';
      if (error?.code === 'model_refusal') return 'model_refusal';
      if (['structured_output_parse','structured_output_missing'].includes(error?.code)) return 'structured_output_parse';
      if (error?.status === 401) return 'authentication';
      if (error?.status === 403) return 'permission';
      if (/insufficient_quota|billing|credit|quota/.test(`${code} ${type} ${message}`)) return 'billing_or_quota';
      if (error?.status === 429 || /rate.?limit/.test(`${code} ${type} ${message}`)) {
        if (/token|tpm/.test(message)) return 'token_rate_limit';
        if (/image|ipm/.test(message)) return 'image_rate_limit';
        if (/request|rpm/.test(message)) return 'request_rate_limit';
        return 'rate_limit';
      }
      if (code === 'context_length_exceeded' || /maximum context|context length|context window/.test(message)) return 'context_length_exceeded';
      if (error?.status === 413 || /too.?large/.test(message)) return 'request_too_large';
      if (error?.status === 400) return 'invalid_request';
      if (error?.status >= 500) return 'openai_server';
      return 'unknown';
    }

    function diagnosticAdvice(classification) {
      const advice = {
        billing_or_quota:'Billing의 결제수단·크레딧 잔액과 조직/프로젝트 월간 사용한도를 확인하세요.',
