        network_or_cors:'OpenAI 응답에 도달하지 못했습니다. 브라우저 CORS, 보안 프로그램, 프록시와 네트워크를 확인하세요.',
        openai_server:'OpenAI 서버 오류입니다. 잠시 기다린 후 같은 client request ID로 재현 여부를 확인하세요.',
        cancelled:'사용자가 요청을 중단했습니다.',
        unknown:'아래 API 원문 message와 request ID를 확인하세요.'
      };
      return advice[classification] || advice.unknown;
