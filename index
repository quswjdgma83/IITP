    function renderVerification() {
      const audit = state.agentAudit;
      const runs = array(state.agentRuns);
      const summaries = runs.map(run => `<div class="agent-trace-row"><div><strong>${e(run.label)}</strong><div class="metric-sub">${e(run.status)} · ${e(run.completed_at || '')}</div></div><div class="agent-trace-summary">${e(compactAgentSummary(run.output?.summary || run.error || '요약 없음'))}</div><div><span class="decision">${e(run.status === '완료' ? '응답 완료' : '실행 실패')}</span></div></div>`).join('');
      const decisions = array(audit?.critic?.decisions);
      const decisionTable = decisions.length ? `<div class="table-wrap"><table class="consensus-table"><thead><tr><th scope="col">쟁점 ID</th><th scope="col">쟁점·제안</th><th scope="col">주요 반론</th><th scope="col">중재 판정</th><th scope="col">근거·최종 지시</th></tr></thead><tbody>${decisions.map(item => `<tr><td>${e(item.issue_id)}</td><td><strong>${e(textOrUnknown(item.topic))}</strong><div class="metric-sub">${e(textOrUnknown(item.proposal))}</div></td><td>${e(textOrUnknown(item.counterargument))}<div class="metric-sub">${e(textOrUnknown(item.reason_summary))}</div></td><td><span class="decision">${e(item.verdict)}</span><div class="metric-sub">${e(item.confidence)}${item.human_confirmation_required ? ' · 사람 확인 필요' : ''}</div></td><td>${agentEvidenceRefs(item.evidence_ids)}<div class="metric-sub">${e(textOrUnknown(item.final_instruction))}</div></td></tr>`).join('')}</tbody></table></div>` : empty('기록된 중재 쟁점이 없습니다.');
      const checks = [...array(audit?.critic?.required_checks).map(item => `필수 확인 · ${item}`),...array(audit?.critic?.limitations).map(item => `한계 · ${item}`),...array(audit?.critic?.rejected_claims).map(item => `기각 주장 · ${item}`)];
      const agentContent = audit ? `<div class="section-card" data-has-agent-audit="true"><div class="section-card-head"><h2>4역할 실행 기록</h2><span class="helper">2개 독립검토·비판중재·최종편집의 실제 API 결과입니다. 내부 사고과정은 표시하지 않습니다.</span></div><div class="agent-trace">${summaries}</div></div><div class="section-card" data-has-agent-audit="true"><div class="section-card-head"><h2>쟁점별 중재 판정표</h2><span class="helper">채택·조건부 채택·기각·판단보류는 과제의 공식 평가결과가 아닙니다.</span></div>${decisionTable}${checks.length ? `<div class="limitation" style="margin-top:12px">${checks.map(item => `<div>${e(item)}</div>`).join('')}</div>` : ''}</div>` : '';
      return `<section class="tab-panel" data-panel="verification" role="tabpanel">${agentContent}<div class="section-card"><div class="section-card-head"><h2>현재 문서 자동 의미검증</h2></div>${state.semanticWarnings.length ? `<ul class="bullet-list">${state.semanticWarnings.map(item => `<li>${e(item)}</li>`).join('')}</ul>` : '<div class="limitation">추가 경고가 발견되지 않았습니다.</div>'}</div></section>`;
    }

    function activateTab(name) {
      $$('.tab-button').forEach(button => {
        const active = button.dataset.tab === name;
        button.classList.toggle('active', active);
        button.setAttribute('aria-selected', String(active));
        button.tabIndex = active ? 0 : -1;
        button.id = `tab-${button.dataset.tab}`;
        button.setAttribute('aria-controls', `panel-${button.dataset.tab}`);
      });
      $$('.tab-panel').forEach(panel => {
        const active = panel.dataset.panel === name;
        panel.classList.toggle('active', active);
        panel.id = `panel-${panel.dataset.panel}`;
        panel.setAttribute('role','tabpanel');
        panel.setAttribute('aria-labelledby',`tab-${panel.dataset.panel}`);
      });
    }

    function bindOutputFilters() {
      const bind = (ids, apply) => ids.forEach(id => { const el = $(`#${id}`); if (el) el.addEventListener('input', apply); });
      bind(['metricSearch','metricInstitution','metricStatus'], () => {
        const query = ($('#metricSearch')?.value || '').trim().toLowerCase(), institution = $('#metricInstitution')?.value || '', status = $('#metricStatus')?.value || '';
        $$('#metricList .metric-row').forEach(row => row.classList.toggle('hidden', !((!query || row.dataset.search.includes(query)) && (!institution || row.dataset.institution === institution) && (!status || row.dataset.status === status))));
      });
      bind(['riskGrade','riskSearch'], () => {
        const grade = $('#riskGrade')?.value || '', query = ($('#riskSearch')?.value || '').trim().toLowerCase();
        $$('#riskList .risk-card').forEach(row => row.classList.toggle('hidden', !((!grade || row.dataset.grade === grade) && (!query || row.dataset.search.includes(query)))));
      });
      bind(['comparisonSearch','comparisonArea','comparisonStatus'], () => {
        const query = ($('#comparisonSearch')?.value || '').trim().toLowerCase(), area = $('#comparisonArea')?.value || '', status = $('#comparisonStatus')?.value || '';
        $$('#comparisonBody tr[data-search]').forEach(row => row.classList.toggle('hidden', !((!query || row.dataset.search.includes(query)) && (!area || row.dataset.area === area) && (!status || row.dataset.status === status))));
      });
      $$('[data-action-field]').forEach(control => control.addEventListener('input', () => {
        const item = state.actionItems[Number(control.dataset.actionIndex)];
        if (item) {
          if (control.dataset.actionField === 'status' && control.value === '확인완료' && (!item.owner.trim() || !item.due_date || !item.memo.trim() || !array(item.evidence_ids).length)) {
            control.value = item.status;
            window.alert('확인완료 전 담당자·기한·메모와 원문 근거가 모두 필요합니다. 근거가 없는 항목은 확인완료로 처리할 수 없습니다.');
            return;
          }
          item[control.dataset.actionField] = control.value;
          state.actionsDirty = true;
        }
      }));
      $$('[data-evidence-ref]').forEach(button => button.addEventListener('click', () => {
        const id = button.dataset.evidenceRef;
        activateTab('evidence');
        requestAnimationFrame(() => {
          const target = document.getElementById(`evidence-${id}`);
          if (target) { target.scrollIntoView({behavior:'smooth',block:'center'}); target.setAttribute('tabindex','-1'); target.focus({preventScroll:true}); }
        });
      }));
    }

