    function renderPreflight() {
      const box = $('#analysisPreflight');
      if (!box) return;
      const files = [state.planFile, ...state.comparisonFiles].filter(Boolean);
      if (!files.length) { box.innerHTML = ''; return; }
      const items = files.map(file => ({file, risk:preflightRisk(file)}));
      const agentMode = $('#analysisModeAgents')?.checked;
      const selectedStrategy = $('#analysisStrategy')?.value || 'auto';
      const staged = files.length > 1 || selectedStrategy === 'staged' || (selectedStrategy === 'auto' && files.reduce((sum,file)=>sum+file.size,0) > 8*1024*1024);
      const estimatedCalls = agentMode ? files.length + 4 : (staged ? files.length + 1 : 1);
      box.innerHTML = `<div class="preflight-item"><strong>예상 API 요청 ${e(estimatedCalls)}회</strong><span> · ${agentMode ? '문서 추출 + 4개 전문역할 순차 실행' : '기본 분석'} · 재시도 별도</span></div>${items.filter(item => item.risk.level !== 'ok').map(({file,risk}) => `<div class="preflight-item ${e(risk.level)}"><strong>${e(risk.label)}</strong><span>${e(file.name)} · ${e(risk.message)}</span></div>`).join('')}`;
