    function preflightRisk(file) {
      const ext = fileExtension(file.name);
      const mb = file.size / 1024 / 1024;
      if (mb >= 50) return {level:'warn', label:'API 한도 주의', message:'첨부는 허용하지만 OpenAI 파일 입력의 파일당 50MB 미만 기준 때문에 API가 거절할 수 있습니다. 실패 시 원문 오류를 확인하세요.'};
      if (ext === 'pdf' && mb >= 8) return {level:'warn', label:'대용량 PDF', message:'첨부와 분석을 허용합니다. 문서별 다단계 처리와 낮은 PDF 정밀도를 적용하며, 토큰 한도 오류가 나면 선택적으로 분할할 수 있습니다.'};
      if (ext === 'pdf' && mb >= 4) return {level:'warn', label:'처리 주의', message:'자동으로 낮은 PDF 정밀도를 사용합니다. 표·도식 판독 결과와 근거 페이지를 반드시 확인하세요.'};
      if (['doc','docx','ppt','pptx'].includes(ext)) return {level:'warn', label:'도표 주의', message:'비PDF 문서의 내장 이미지·복잡한 도표는 충분히 판독되지 않을 수 있습니다. 필요하면 PDF도 함께 제공하세요.'};
      if (['xls','xlsx','csv'].includes(ext)) return {level:'warn', label:'행 범위 주의', message:'대형 스프레드시트는 일부 행이 누락될 수 있습니다. 핵심 실적표를 별도 PDF 또는 CSV로 제공하세요.'};
      return {level:'ok', label:'기본 점검 통과', message:'형식과 파일 크기 기준의 즉시 차단 사유는 없습니다.'};
